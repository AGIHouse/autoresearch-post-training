\@writefile{toc}{\contentsline {subsection}{\numberline {3.10}Score Distribution and Rolling Mean}{10}{subsection.3.10}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces \textbf  {(A)} Boxplots of pass@1 across post-baseline iterations for each run. Run\nobreakspace  {}2 has the highest median despite sharing the same worst score as Run\nobreakspace  {}1. Run\nobreakspace  {}3 has only 2 post-baseline observations, so its box degenerates to a line. \textbf  {(B)} Run\nobreakspace  {}1 raw pass@1 and a 3-iteration rolling mean, showing the underlying downward trend followed by late recovery.\relax }}{10}{figure.caption.11}\protected@file@percent }
\newlabel{fig:distribution}{{10}{10}{\textbf {(A)} Boxplots of pass@1 across post-baseline iterations for each run. Run~2 has the highest median despite sharing the same worst score as Run~1. Run~3 has only 2 post-baseline observations, so its box degenerates to a line. \textbf {(B)} Run~1 raw pass@1 and a 3-iteration rolling mean, showing the underlying downward trend followed by late recovery.\relax }{figure.caption.11}{}}
